#!/bin/sh
# Rust pre-commit checks: formatting, lint, tests.
# Tracked in .githooks/ and wired up via `git config core.hooksPath .githooks`.

set -e

echo "pre-commit: cargo fmt --check"
cargo fmt --all -- --check

echo "pre-commit: cargo clippy"
cargo clippy --all-targets -- -D warnings

echo "pre-commit: cargo test"
cargo test
